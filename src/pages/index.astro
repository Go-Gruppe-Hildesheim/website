---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Go-Gruppe Hildesheim">
  <main class="min-h-screen bg-base-100">
    <!-- Hero Section -->
    <div class="hero min-h-screen">
      <div class="hero-content text-center">
        <div class="max-w-md">
          <h1 class="text-5xl font-bold text-primary mb-8">Go-Gruppe Hildesheim</h1>
          <p class="text-lg mb-6">
            Willkommen bei der Go-Gruppe Hildesheim! Wir sind eine Gemeinschaft von 
            Go-Enthusiasten, die sich regelmäßig treffen, um das faszinierende 
            Brettspiel Go zu spielen und zu erlernen.
          </p>
          <div class="card bg-base-200 shadow-xl p-6 mb-6">
            <h2 class="text-2xl font-semibold mb-4">Treffen</h2>
            <p class="text-lg">
              📅 <strong>Jeden Dienstag um 18 Uhr</strong><br/>
              📍 <strong>im <a href="https://www.cafedeseo.de/" class="link link-primary" target="_blank" rel="noopener noreferrer">Deseo</a></strong><br/>
              Eine gemütliche Bar in Hildesheim
            </p>
          </div>
          <p class="text-base-content/70 mb-8">
            Egal ob Anfänger oder erfahrener Spieler - alle sind herzlich willkommen! 
            Komm einfach vorbei und lerne dieses wunderbare Spiel kennen oder 
            verbessere deine Fähigkeiten in entspannter Atmosphäre.
          </p>
        </div>
      </div>
    </div>

    <!-- Footer with Imprint -->
    <footer class="footer footer-center p-10 bg-base-200 text-base-content">
      <div>
        <h3 class="font-bold text-lg">Impressum</h3>
        <p>
          Verantwortlich für den Inhalt dieser Webseite:<br/>
          <strong>Levin Keller</strong><br/>
          Hohenzollerndamm 152<br/>
          14199 Berlin
        </p>
      </div>
    </footer>
  </main>
</Layout>