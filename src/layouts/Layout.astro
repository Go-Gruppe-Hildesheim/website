---
export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="description" content="Go-Gruppe Hildesheim - Wir treffen uns jeden Dienstag im Deseo" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
  <script is:inline defer data-domain="go-hildesheim.de" src="https://analytics.levinkeller.de/js/script.js"></script>
</head>
<body>
  <slot />
</body>
</html>
